# ============================================================
# AI Tutor Agent — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# LLM provider: 'openai' | 'claude' | 'gemini'
LLM_PROVIDER=claude

# OpenAI (also required for embeddings regardless of LLM_PROVIDER)
OPENAI_API_KEY=sk-...

# Anthropic Claude (recommended — uses claude-sonnet-4-6)
CLAUDE_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Server port (default: 4000)
PORT=4000

# Max file size in MB (default: 20)
MAX_FILE_SIZE_MB=20

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Top-K chunks to retrieve per query (default: 5)
RETRIEVAL_TOP_K=5

# CORS allowed origin for deployed frontend
ALLOWED_ORIGIN=http://localhost:5173
